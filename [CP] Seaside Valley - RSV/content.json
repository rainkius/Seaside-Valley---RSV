{
   "Format": "2.9.0",
   "ConfigSchema": {
       //Master Options       
       "HudsonValleyBuildings": {
			"AllowValues": "true, false",
			"Default": "true",
            "Description": "Replace the farm buildings on the RSV map with a custom recolor of Hudson Valley Buildings (coops, barn, etc), based on the Stonybrook color. **The foliage and snow on these buildings are Earthy Recolour**",
            "Section": "Town"
		},
        "LiteMode": {
			"AllowValues": "true, false",
			"Default": "false",
            "Description": "Disables most of the unique location edits & customizations to improve loading time (important graphical fixes are still available). The town framing, furniture, and door color options will be used everywhere. Map edits will still apply if they are enabled. Defaults to FALSE - set to true only if you are having trouble with location-switch lag and don't mind the lack of customization.",
            "Section": "Master Options"
		},
        
    },
    "DynamicTokens": [
		{
		"Name": "SVE",
		"Value": "false",
		},
		{
		"Name": "SVE",
		"Value": "true",
			"When": { "HasMod" : "FlashShifter.StardewValleyExpandedCP"},
		},        
	],
    
    
   "Changes": [
    
    //Main Town
        {
            "LogName": "Tilesheet Overlays",
            "Action": "EditImage",
            "PatchMode": "Overlay",
            "Target": "Maps/{{season}}_zridgesidebuildings, Maps/{{season}}_zridgetiles, Maps/{{season}}_zrsvcablecar, Maps/{{season}}_zrsvcliffhouse, Maps/{{season}}_zrsvscene1, Maps/FreddieShedItems, Maps/zFreddieShedItems",
            "FromFile": "assets/Tilesheets/{{TargetWithoutPath}}.png",            
        },
        {
            "LogName": "Tilesheet Complete Replacements",
